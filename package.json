{
  "name": "@dnd-mapp/shared-ui-source",
  "description": "Official Angular component library for the D&D Mapp platform.",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "author": "NoNamer777",
  "homepage": "https://github.com/dnd-mapp/shared-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnd-mapp/shared-ui.git"
  },
  "bugs": {
    "url": "https://github.com/dnd-mapp/shared-ui/issues"
  },
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "projects/*"
  ],
  "type": "module",
  "engines": {
    "node": "~24.14"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "~24.14",
      "onFail": "error"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "10.33.0",
        "onFail": "error"
      }
    ]
  },
  "scripts": {
    "prepublishOnly": "node tools/prepublish-only.js",
    "ng": "pnpm exec ng",
    "build": "pnpm exec ng build",
    "build-dev": "pnpm exec ng build -c development",
    "storybook:build": "pnpm exec ng run shared-ui:build-storybook",
    "storybook:start": "pnpm exec ng run shared-ui:storybook",
    "format:check": "pnpm exec prettier -l .",
    "format:write": "pnpm exec prettier -w .",
    "lint": "pnpm exec ng lint",
    "stylelint": "pnpm exec stylelint \"**/*.scss\""
  },
  "dependencies": {
    "@angular/cdk": "~21.2",
    "@angular/common": "~21.2",
    "@angular/compiler": "~21.2",
    "@angular/core": "~21.2",
    "@angular/forms": "~21.2",
    "@angular/router": "~21.2",
    "rxjs": "~7.8",
    "tslib": "~2.8"
  },
  "devDependencies": {
    "@angular-eslint/builder": "~21.3",
    "@angular/build": "~21.2",
    "@angular/cli": "~21.2",
    "@angular/compiler-cli": "~21.2",
    "@angular/platform-browser-dynamic": "~21.2",
    "@eslint/js": "~10.0",
    "@storybook/addon-a11y": "~10.3",
    "@storybook/addon-docs": "~10.3",
    "@storybook/angular": "~10.3",
    "@types/node": "~24.12",
    "angular-eslint": "~21.3",
    "eslint": "~10.2",
    "eslint-config-prettier": "~10.1",
    "eslint-plugin-storybook": "~10.3",
    "ng-packagr": "~21.2",
    "prettier": "~3.8",
    "prettier-plugin-organize-imports": "~4.3",
    "storybook": "~10.3",
    "stylelint": "~17.6",
    "stylelint-config-standard-scss": "~17.0",
    "typescript": "~5.9",
    "typescript-eslint": "~8.58"
  }
}
