{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "cli": {
        "packageManager": "pnpm",
        "schematicCollections": ["angular-eslint"],
        "analytics": "897852a2-a744-4f49-8882-96c10836f56a"
    },
    "newProjectRoot": "projects",
    "projects": {
        "shared-ui": {
            "projectType": "library",
            "root": "",
            "sourceRoot": "src",
            "prefix": "dma",
            "architect": {
                "build": {
                    "builder": "@angular/build:ng-packagr",
                    "defaultConfiguration": "production",
                    "configurations": {
                        "production": {
                            "tsConfig": "tsconfig.lib.prod.json"
                        },
                        "development": {
                            "tsConfig": "tsconfig.lib.json",
                            "watch": true
                        }
                    }
                },
                "lint": {
                    "builder": "@angular-eslint/builder:lint",
                    "options": {
                        "lintFilePatterns": ["src/**/*.ts", "src/**/*.html", ".storybook/**/*.ts"],
                        "eslintConfig": "eslint.config.mjs"
                    }
                },
                "build-storybook": {
                    "builder": "@storybook/angular:build-storybook",
                    "options": {
                        "assets": [
                            {
                                "input": "src/assets",
                                "glob": "**/*",
                                "output": "assets"
                            }
                        ],
                        "browserTarget": "shared-ui:build",
                        "compodoc": false,
                        "configDir": ".storybook",
                        "experimentalZoneless": true,
                        "outputDir": "dist/storybook-static",
                        "styles": [".storybook/styles.scss"]
                    }
                },
                "storybook": {
                    "builder": "@storybook/angular:start-storybook",
                    "options": {
                        "assets": [
                            {
                                "input": "src/assets",
                                "glob": "**/*",
                                "output": "assets"
                            }
                        ],
                        "browserTarget": "shared-ui:build",
                        "compodoc": false,
                        "configDir": ".storybook",
                        "experimentalZoneless": true,
                        "open": false,
                        "port": 6006,
                        "styles": [".storybook/styles.scss"]
                    }
                }
            }
        }
    },
    "schematics": {
        "@schematics/angular:component": {
            "addTypeToClassName": true,
            "changeDetection": "OnPush",
            "skipTests": true,
            "style": "scss",
            "type": "component"
        },
        "@schematics/angular:directive": {
            "addTypeToClassName": true,
            "skipTests": true,
            "type": "directive"
        }
    }
}
