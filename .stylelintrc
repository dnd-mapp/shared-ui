{
    "extends": ["stylelint-config-standard-scss"],
    "cache": true,
    "rules": {
        "at-rule-no-unknown": [
            true,
            {
                "ignoreAtRules": [
                    "plugin",
                    "reference",
                    "source"
                ]
            }
        ],
        "import-notation": null
    }
}
