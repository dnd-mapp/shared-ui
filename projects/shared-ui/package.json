{
  "name": "@dnd-mapp/shared-ui",
  "version": "2.0.1",
  "description": "Official Angular component library for the D&D Mapp platform.",
  "author": "NoNamer777",
  "license": "UNLICENSED",
  "keywords": [
    "angular",
    "component-library",
    "ui-kit"
  ],
  "homepage": "https://github.com/dnd-mapp/shared-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnd-mapp/shared-ui.git",
    "directory": "projects/shared-ui"
  },
  "bugs": {
    "url": "https://github.com/dnd-mapp/shared-ui"
  },
  "exports": {
    "./fonts/*": "./assets/fonts/*",
    "./images/*": "./assets/images/*",
    "./styles/*": "./assets/styles/*",
    "./styles/colors": {
      "sass": "./assets/styles/colors/index.scss"
    },
    "./styles/fonts": {
      "sass": "./assets/styles/fonts.scss"
    },
    "./styles/main": {
      "sass": "./assets/styles/main.scss"
    },
    "./styles/theme-variables": {
      "sass": "./assets/styles/theme-variables/index.scss"
    }
  },
  "type": "module",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.30.3"
  },
  "peerDependencies": {
    "@angular/cdk": "~21.2",
    "@angular/common": "~21.2",
    "@angular/core": "~21.2",
    "@angular/forms": "~21.2",
    "@angular/router": "~21.2"
  },
  "dependencies": {
    "tslib": "~2.8"
  }
}
